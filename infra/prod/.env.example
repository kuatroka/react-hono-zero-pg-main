# Shared stack identity
COMPOSE_PROJECT_NAME=fintellectus
POSTGRES_CONTAINER_NAME=sec_postgres_18
APP_CONTAINER_NAME=fintellectus_app
ZERO_CONTAINER_NAME=fintellectus_zero_cache

# Host paths and bind addresses
APP_DATA_HOST_PATH=/opt/dev/erudio_app/app_data
POSTGRES_BIND_HOST=127.0.0.1
POSTGRES_BIND_PORT=5432
APP_BIND_HOST=127.0.0.1
APP_BIND_PORT=3000
ZERO_BIND_HOST=127.0.0.1
ZERO_BIND_PORT=4848
CADDY_SITE_PATH=/etc/caddy/sites/fintellectus.Caddyfile

# Public routing
APP_DOMAIN=app.example.com
ZERO_DOMAIN=sync-app.example.com
APP_PUBLIC_URL=https://app.example.com
ZERO_PUBLIC_URL=https://sync-app.example.com

# Postgres / pipeline compatibility
POSTGRES_IMAGE=mooncakelabs/pg_mooncake:18-v0.2-preview
POSTGRES_VOLUME_NAME=sec_pgdata
POSTGRES_USER=user
POSTGRES_PASSWORD=replace-me
POSTGRES_DB=postgres
DUCKDB_FORCE_EXECUTION=off

# Bun app runtime
APP_IMAGE=fintellectus-app:latest
API_PORT=3000
ZERO_UPSTREAM_DB=postgresql://user:replace-me@postgres:5432/postgres
ZERO_AUTH_SECRET=replace-me

# Zero single-node runtime
ZERO_IMAGE=rocicorp/zero:1.0.0
ZERO_REPLICA_VOLUME_NAME=fintellectus_zero_cache
ZERO_REPLICA_FILE=/var/lib/zero/replica.db
ZERO_CVR_DB=postgresql://user:replace-me@postgres:5432/postgres
ZERO_CHANGE_DB=postgresql://user:replace-me@postgres:5432/postgres
ZERO_QUERY_URL=https://app.example.com/api/zero/get-queries
ZERO_QUERY_FORWARD_COOKIES=true
ZERO_APP_PUBLICATIONS=zapp_app
ZERO_ADMIN_PASSWORD=replace-me

# Deployment paths
DEPLOY_APP_DIR=/opt/dev/erudio_app/react-hono-zero-pg-main

# Set only after migrating away from legacy CRUD mutators.
# ZERO_MUTATE_URL=https://app.example.com/api/zero/mutate

